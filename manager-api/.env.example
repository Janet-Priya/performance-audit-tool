# Copy to .env and adjust. Manager API reads these at process start.
# Example: export $(grep -v '^#' .env | xargs) && uvicorn main:app --port 8001

# UI + HTML report branding (optional — sensible defaults exist)
# AUDIT_APP_TITLE=Performance audit
# AUDIT_APP_SUBTITLE=Load testing and latency insights
# AUDIT_REPORT_TITLE=
# AUDIT_REPORT_SUBTITLE=
# AUDIT_REPORT_FOOTER=Print this page (Ctrl/Cmd+P) to save as PDF

# OpenAPI browser title
# AUDIT_API_TITLE=Latency audit API

# Comma-separated origins for the React dashboard (defaults include localhost and 127.0.0.1 on port 3000)
# AUDIT_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
