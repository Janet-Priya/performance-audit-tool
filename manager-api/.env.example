# Copy to .env and adjust. Manager API reads these at process start.
# Example: export $(grep -v '^#' .env | xargs) && uvicorn main:app --port 8001

# SQLite path (default: results.db in cwd). Docker Compose sets /data/results.db.
# AUDIT_DB_PATH=results.db

# UI + HTML report branding (optional — sensible defaults exist)
# AUDIT_APP_TITLE=Performance audit
# AUDIT_APP_SUBTITLE=Load testing and latency insights
# AUDIT_REPORT_TITLE=
# AUDIT_REPORT_SUBTITLE=
# AUDIT_REPORT_FOOTER=Print this page (Ctrl/Cmd+P) to save as PDF

# OpenAPI browser title
# AUDIT_API_TITLE=Latency audit API

# Comma-separated origins for the React dashboard (defaults include localhost and 127.0.0.1 on port 3000)
# AUDIT_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: require X-API-Key header on mutating routes (run test, pin/clear baseline).
# Leave unset for local-only use.
# AUDIT_API_KEY=

# Optional: comma-separated hostnames allowed in target_url (e.g. localhost,127.0.0.1). Empty = no restriction.
# AUDIT_ALLOWED_TARGET_HOSTS=localhost,127.0.0.1

# Docker: if the UI sends http://localhost:8000, the manager container would load-test itself. Rewrite to the real target:
# AUDIT_REPLACE_LOCALHOST_TARGET=http://target-api:8000

# Max POST /api/tests/run per client IP per minute (0 = disable)
# AUDIT_RATE_LIMIT_PER_MINUTE=30
