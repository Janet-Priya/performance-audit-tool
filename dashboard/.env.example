# Create .env in this folder (Create React App loads it at build/dev time).

# Manager API base URL (always use absolute URL for builds — see README).
# Development: defaults to http://127.0.0.1:8001 if unset.
# REACT_APP_API_URL=http://127.0.0.1:8001

# Base URL of the service under load (sent to POST /api/tests/run). Local dev: http://localhost:8000.
# Docker Compose (dashboard + manager + target): use http://target-api:8000 so the manager container can reach the target.
# REACT_APP_TARGET_URL=http://localhost:8000

# If the manager has AUDIT_API_KEY set, set the same value here (sent as X-API-Key).
# Note: anything in the frontend bundle is visible to users — use only on trusted networks.
# REACT_APP_AUDIT_API_KEY=
